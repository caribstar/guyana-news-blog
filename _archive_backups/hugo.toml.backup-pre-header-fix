baseURL = "https://tradewindsbrief.com/"
languageCode = "en-us"
title = "The Tradewinds Brief"
description = "Diaspora-first reporting on Guyana, the Caribbean, and Africa. The news, the satire, and the serious coverage these communities deserve. Free, daily."
theme = "PaperMod"

[pagination]
pagerSize = 10

enableEmoji = true
enableRobotsTXT = true
buildDrafts = false
buildFuture = false

[outputs]
home = ["HTML", "RSS", "JSON"]

[params]
images = ["/images/social-share.png"]
defaultDescription = "Diaspora-first reporting on Guyana, the Caribbean, and Africa. Free, daily."
[params.label]
  icon = "/images/logo.jpg"
  iconHeight = 35
favicon = "/favicon.svg"

description = "Diaspora-first reporting on Guyana, the Caribbean, and Africa. Free, daily."
author = "CARIBSTAR"
env = "production"
ShowReadingTime = true
ShowShareButtons = true
ShareButtons = ["facebook", "x", "whatsapp", "telegram"]
ShowPostNavLinks = true
ShowBreadCrumbs = true
ShowCodeCopyButtons = true
ShowWordCount = true
ShowRssButtonInSectionTermList = true
ShowToc = false
TocOpen = false
comments = false

[params.homeInfoParams]
title = "The Tradewinds Brief"
description = "Diaspora-first reporting on Guyana, the Caribbean, and Africa. The news, the satire, and the serious coverage these communities deserve. Free, daily."
Content = "Diaspora-first reporting on Guyana, the Caribbean, and Africa. Daily."


