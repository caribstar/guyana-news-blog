{{ define "main" }}
<div class="indo-hub">
  
  <!-- Header -->
  <div class="indo-header">
    <h1>&#127470;&#127475; Indo-Caribbean Brief</h1>
    <p class="tagline">The Indo-Caribbean Brief covers Guyana, Trinidad, Suriname, and the diaspora with the attention the Indian-heritage Caribbean deserves &mdash; whether that means analyzing strategic relationships or explaining how this culture actually formed.</p>
  </div>

  <!-- About Section -->
  <div class="indo-about">
    <p>Two columns. Four countries of focus. <strong>One standard of attention.</strong></p>
    <p class="about-detail">The Georgetown Ledger covers Guyana&#x2019;s strategic and diplomatic relationships. Cane Fields covers Indo-Caribbean cultural identity and heritage. Same editorial brain: intelligent, specific, non-generic. Built for the Indo-Caribbean diaspora from Georgetown to Queens to Toronto to London.</p>
  </div>

  <!-- Regional Roundup Section - ACTIVE -->
  <div class="section-active">
    <h2>&#128240; Latest Dispatches</h2>
    <p>Strategic analysis and cultural reporting from across the Indo-Caribbean world.</p>
    <a href="/categories/indo-caribbean-brief/" class="btn-regional">Read Latest Indo-Caribbean Brief &#8594;</a>
  </div>

  <!-- Column Grid -->
  <div class="column-section">
    <h2>&#128218; Columns</h2>
    <p class="intro-note">Two perspectives. One editorial brain.</p>
    
    <div class="column-grid">

      <!-- Georgetown Ledger - ACTIVE -->
      <div class="column-card active">
        <span class="col-label">GL</span>
        <h3>Georgetown Ledger</h3>
        <p>Strategic analysis of Guyana&#x2019;s Indo-Caribbean relationships</p>
        <a href="/categories/georgetown-ledger/" class="btn-column">Read Weekly &#8594;</a>
      </div>

      <!-- Cane Fields - ACTIVE -->
      <div class="column-card active">
        <span class="col-label">CF</span>
        <h3>Cane Fields</h3>
        <p>The real stories behind Indo-Caribbean cultural identity</p>
        <a href="/categories/cane-fields/" class="btn-column">Read Weekly &#8594;</a>
      </div>

      <!-- Trinidad Voice - PLACEHOLDER -->
      <div class="column-card placeholder">
        <span class="col-label">TT</span>
        <h3>Trinidad Voice</h3>
        <p>Indo-Trinidadian perspectives &mdash; coming soon</p>
        <span class="btn-placeholder">Launching soon</span>
      </div>

      <!-- Diaspora Ledger - PLACEHOLDER -->
      <div class="column-card placeholder">
        <span class="col-label">DL</span>
        <h3>Diaspora Ledger</h3>
        <p>NY, Toronto, London &mdash; coming soon</p>
        <span class="btn-placeholder">Launching soon</span>
      </div>

    </div>
  </div>

  <!-- Newsletter CTA -->
  <div class="newsletter-cta">
    <h3>&#128236; Get the Indo-Caribbean Brief in Your Inbox</h3>
    <p>Weekly dispatches from Georgetown to Queens. No spam. Just specificity.</p>
    <a href="/#newsletter" class="btn-subscribe">Subscribe Free</a>
  </div>

</div>

<style>
.indo-hub { max-width: 1000px; margin: 0 auto; padding: 2rem 1rem; }
.indo-header { text-align: center; margin-bottom: 2rem; padding: 2rem; background: linear-gradient(135deg, #FF9933 0%, #FFFFFF 50%, #138808 100%); border-radius: 12px; color: #333; }
.indo-header h1 { font-size: 2.5rem; margin-bottom: 0.5rem; text-shadow: 1px 1px 2px rgba(0,0,0,0.2); color: #333; }
.indo-header .tagline { font-size: 1.1rem; opacity: 0.95; font-style: italic; color: #222; max-width: 800px; margin: 0 auto; }
.indo-about { background: #fff; border: 1px solid #e0e0e0; border-left: 4px solid #FF9933; border-radius: 8px; padding: 1.5rem 2rem; margin-bottom: 3rem; }
.indo-about p { margin: 0 0 0.75rem 0; font-size: 1.05rem; line-height: 1.5; color: #333; }
.indo-about p:last-child { margin-bottom: 0; }
.indo-about .about-detail { font-size: 0.95rem; color: #555; }
.section-active { background: #fff4e6; border: 2px solid #FF9933; border-radius: 12px; padding: 2rem; text-align: center; margin-bottom: 3rem; }
.section-active h2 { color: #D66B00; margin-bottom: 0.5rem; }
.btn-regional { display: inline-block; background: #FF9933; color: white; padding: 1rem 2rem; border-radius: 8px; text-decoration: none; font-weight: bold; margin-top: 1rem; transition: all 0.3s ease; }
.btn-regional:hover { background: #D66B00; transform: translateY(-2px); }
.column-section { margin-bottom: 3rem; }
.column-section h2 { text-align: center; margin-bottom: 0.5rem; }
.intro-note { text-align: center; color: #666; margin-bottom: 2rem; font-style: italic; }
.column-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
.column-card { background: white; border: 2px solid #e0e0e0; border-radius: 12px; padding: 1.5rem; text-align: center; transition: all 0.3s ease; }
.column-card .col-label { font-size: 1.5rem; font-weight: bold; display: block; margin-bottom: 0.5rem; color: #FF9933; letter-spacing: 2px; }
.column-card h3 { margin: 0.5rem 0; font-size: 1.1rem; }
.column-card p { color: #666; font-size: 0.9rem; margin: 0.5rem 0; }
.column-card.active { border-color: #FF9933; background: #fff4e6; }
.column-card.active:hover { transform: translateY(-4px); box-shadow: 0 8px 25px rgba(255, 153, 51, 0.25); }
.column-card.placeholder { background: #f5f5f5; opacity: 0.7; }
.btn-column { display: inline-block; background: #FF9933; color: white; padding: 0.5rem 1rem; border-radius: 6px; text-decoration: none; font-size: 0.85rem; font-weight: bold; margin-top: 0.5rem; transition: all 0.3s ease; }
.btn-column:hover { background: #D66B00; }
.btn-placeholder { display: inline-block; background: #bdbdbd; color: white; padding: 0.5rem 1rem; border-radius: 6px; font-size: 0.85rem; font-weight: bold; margin-top: 0.5rem; }
.newsletter-cta { background: linear-gradient(135deg, #FF9933 0%, #D66B00 100%); border-radius: 12px; padding: 2rem; text-align: center; }
.newsletter-cta h3 { margin-bottom: 0.5rem; color: #fff; }
.newsletter-cta p { color: #fff; margin-bottom: 1rem; opacity: 0.95; }
.btn-subscribe { display: inline-block; background: #333; color: white; padding: 1rem 2rem; border-radius: 8px; text-decoration: none; font-weight: bold; transition: all 0.3s ease; }
.btn-subscribe:hover { background: #000; transform: translateY(-2px); }
@media (max-width: 768px) {
  .column-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .indo-header h1 { font-size: 1.8rem; }
  .column-card { padding: 1rem; }
  .column-card .col-label { font-size: 1.2rem; }
}
</style>
{{ end }}