# ==========================
# Hugo output / build folders
# ==========================
/public/
resources/_gen/
hugo_stats.json
hugo_build.lock

# ==========================
# OS files
# ==========================
.DS_Store
Thumbs.db
desktop.ini

# ==========================
# Temporary / swap files
# ==========================
*.swp
*.swo
*.tmp
*.log

# ==========================
# Node / package manager stuff
# ==========================
node_modules/
npm-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ==========================
# Backup / PowerShell or editor backups
# ==========================
*.backup-*

# ==========================
# IDE / editor folders
# ==========================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ==========================
# Theme caches (if using themes)
# ==========================
themes/*/resources/_gen/
themes/*/package-lock.json
themes/*/node_modules/
