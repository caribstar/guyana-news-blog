{{ define "main" }}
<div class="africa-hub">
  
  <!-- Header -->
  <div class="africa-header">
    <h1>&#127758; Africa Brief</h1>
    <p class="tagline">Politics, policy, and pulse from across the continent</p>
  </div>

  <!-- Regional Roundup Section - ACTIVE -->
  <div class="section-active">
    <h2>&#128240; Regional Roundup</h2>
    <p>Weekly dispatches from Accra, Nairobi, and beyond.</p>
    <a href="/categories/africa-brief/" class="btn-regional">Read Latest Africa Brief &#8594;</a>
  </div>

  <!-- Country Grid -->
  <div class="country-section">
    <h2>&#127759; Country Briefs</h2>
    <p class="coming-soon-note">One voice per country. More nations coming.</p>
    
    <div class="country-grid">

      <!-- Ghana - ACTIVE -->
      <div class="country-card active">
        <span class="flag">GH</span>
        <h3>Ghana Brief</h3>
        <p>The Accra Almanac: Mahama, mines, and markets</p>
        <a href="/categories/ghana-brief/" class="btn-country">Read Weekly &#8594;</a>
      </div>

      <!-- Kenya - ACTIVE -->
      <div class="country-card active">
        <span class="flag">KE</span>
        <h3>Kenya Brief</h3>
        <p>The Nairobi Dispatch: Ruto, protests, and the 2027 horizon</p>
        <a href="/categories/kenya-brief/" class="btn-country">Read Weekly &#8594;</a>
      </div>

      <!-- Nigeria - PLACEHOLDER -->
      <div class="country-card placeholder">
        <span class="flag">NG</span>
        <h3>Naija Brief</h3>
        <p>Coming soon</p>
        <span class="btn-placeholder">In Development</span>
      </div>

      <!-- South Africa - PLACEHOLDER -->
      <div class="country-card placeholder">
        <span class="flag">ZA</span>
        <h3>Mzansi Brief</h3>
        <p>Coming soon</p>
        <span class="btn-placeholder">In Development</span>
      </div>

    </div>
  </div>

  <!-- Newsletter CTA -->
  <div class="newsletter-cta">
    <h3>&#128236; Get Africa in Your Inbox</h3>
    <p>Weekly dispatches from the continent. No spam. Just news and analysis.</p>
    <a href="/#newsletter" class="btn-subscribe">Subscribe Free</a>
  </div>

</div>

<style>
.africa-hub { max-width: 1000px; margin: 0 auto; padding: 2rem 1rem; }
.africa-header { text-align: center; margin-bottom: 3rem; padding: 2rem; background: linear-gradient(135deg, #FCD116 0%, #CE1126 50%, #009E60 100%); border-radius: 12px; color: white; }
.africa-header h1 { font-size: 2.5rem; margin-bottom: 0.5rem; text-shadow: 2px 2px 4px rgba(0,0,0,0.3); }
.africa-header .tagline { font-size: 1.2rem; opacity: 0.95; font-style: italic; }
.section-active { background: #fff8e1; border: 2px solid #FFA000; border-radius: 12px; padding: 2rem; text-align: center; margin-bottom: 3rem; }
.section-active h2 { color: #E65100; margin-bottom: 0.5rem; }
.btn-regional { display: inline-block; background: #FFA000; color: white; padding: 1rem 2rem; border-radius: 8px; text-decoration: none; font-weight: bold; margin-top: 1rem; transition: all 0.3s ease; }
.btn-regional:hover { background: #E65100; transform: translateY(-2px); }
.country-section { margin-bottom: 3rem; }
.country-section h2 { text-align: center; margin-bottom: 0.5rem; }
.coming-soon-note { text-align: center; color: #666; margin-bottom: 2rem; font-style: italic; }
.country-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
.country-card { background: white; border: 2px solid #e0e0e0; border-radius: 12px; padding: 1.5rem; text-align: center; transition: all 0.3s ease; }
.country-card .flag { font-size: 2rem; font-weight: bold; display: block; margin-bottom: 0.5rem; color: #333; }
.country-card h3 { margin: 0.5rem 0; font-size: 1.1rem; }
.country-card p { color: #666; font-size: 0.9rem; margin: 0.5rem 0; }
.country-card.active { border-color: #FFA000; background: #fff8e1; }
.country-card.active:hover { transform: translateY(-4px); box-shadow: 0 8px 25px rgba(255, 160, 0, 0.25); }
.country-card.placeholder { background: #f5f5f5; opacity: 0.7; }
.btn-country { display: inline-block; background: #FFA000; color: white; padding: 0.5rem 1rem; border-radius: 6px; text-decoration: none; font-size: 0.85rem; font-weight: bold; margin-top: 0.5rem; transition: all 0.3s ease; }
.btn-country:hover { background: #E65100; }
.btn-placeholder { display: inline-block; background: #bdbdbd; color: white; padding: 0.5rem 1rem; border-radius: 6px; font-size: 0.85rem; font-weight: bold; margin-top: 0.5rem; }
.newsletter-cta { background: linear-gradient(135deg, #FCD116 0%, #FFA000 100%); border-radius: 12px; padding: 2rem; text-align: center; }
.newsletter-cta h3 { margin-bottom: 0.5rem; color: #333; }
.newsletter-cta p { color: #555; margin-bottom: 1rem; }
.btn-subscribe { display: inline-block; background: #333; color: white; padding: 1rem 2rem; border-radius: 8px; text-decoration: none; font-weight: bold; transition: all 0.3s ease; }
.btn-subscribe:hover { background: #000; transform: translateY(-2px); }
@media (max-width: 768px) {
  .country-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .africa-header h1 { font-size: 1.8rem; }
  .country-card { padding: 1rem; }
  .country-card .flag { font-size: 1.5rem; }
}
</style>
{{ end }}